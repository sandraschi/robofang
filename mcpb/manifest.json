{
    "manifest_version": "0.2",
    "name": "robofang",
    "version": "0.3.0",
    "description": "RoboFang Sovereign Orchestration Hub",
    "author": {
        "name": "Sandra Schipal"
    },
    "server": {
        "type": "python",
        "entry_point": "src/robofang/main.py",
        "mcp_config": {
            "command": "python",
            "args": [
                "-m",
                "robofang.main"
            ],
            "env": {
                "PYTHONPATH": "${PWD}/src",
                "PYTHONUNBUFFERED": "1"
            }
        }
    },
    "user_config": {
        "port": {
            "type": "string",
            "title": "Bridge Port",
            "default": "10870"
        }
    },
    "tools": [
        {
            "name": "get_fleet_status",
            "description": "Get real-time status of all registered MCP servers in the fleet."
        },
        {
            "name": "orchestrate_mission",
            "description": "Trigger a multi-step sovereign mission across selected fleet nodes."
        }
    ]
}