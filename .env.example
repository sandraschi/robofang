# OpenFang Environment Configuration
# Copy to .env and fill in real values. Never commit .env to git.

# ── Connector Selection ─────────────────────────────────────────────────────
# Comma-separated list of connectors to activate at startup.
# Overrides federation_map.json. Leave unset to use federation_map settings.
# Available: moltbook, resonite, email, iot, social
#
# OPENFANG_CONNECTORS=moltbook

# ── Moltbook ────────────────────────────────────────────────────────────────
MOLTBOOK_API_KEY=your_moltbook_api_key_here

# ── Ollama / Local LLM ──────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434

# ── Resonite (only needed if resonite connector is enabled) ─────────────────
RESONITE_HOST=localhost
RESONITE_PORT=4242

# ── Email (only needed if email connector is enabled) ────────────────────────
EMAIL_HOST=imap.example.com
EMAIL_PORT=993
EMAIL_USER=you@example.com
EMAIL_PASSWORD=your_email_password

# ── Dark App Factory (future connector) ─────────────────────────────────────
# DAF_ENDPOINT=http://localhost:19300
