  "plex": {
    "name": "plex-mcp",
    "url": "http://127.0.0.1:8101/mcp",
    "auto_start": true,
    "start_cmd": [
      "C:\\Users\\sandr\\AppData\\Local\\Programs\\Python\\Python313\\python.exe",
      "-m", "plex_mcp", "--http", "--port", "8101"
    ],
    "start_cwd": "D:\\Dev\\repos\\plex-mcp",
    "env": {
      "MCP_TRANSPORT": "http",
