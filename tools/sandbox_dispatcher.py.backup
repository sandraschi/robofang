import os
import json
import time
import sys
from typing import Dict, Any
from pathlib import Path

# Add src to path if needed to find openfang.core
sys.path.append(str(Path(__file__).parent.parent / "src"))

try:
    from openfang.core.bastion import LocalBastionManager
    from openfang.core.bastio import BastioGateway
except ImportError:
    # Fallback for isolated execution
    LocalBastionManager = None
    BastioGateway = None


class SandboxDispatcher:
    """
    OpenFang Sandbox Dispatcher
    Orchestrates the execution of tasks within Windows Sandboxes.
    """

    def __init__(self, root_dir: str, use_dtu: bool = True):
        self.root = Path(root_dir)
        self.exchange_dir = self.root / "exchange" / "sandbox"
        self.exchange_dir.mkdir(parents=True, exist_ok=True)
        self.wsb_template = self.root / "containers" / "agent_template.wsb"
        self.use_dtu = use_dtu

        # Security Primitives
        self.bastion = LocalBastionManager() if LocalBastionManager else None
        self.bastio = (
            BastioGateway(api_key=os.environ.get("BASTIO_API_KEY"))
            if BastioGateway
            else None
        )

        # DTU Configuration (Mirror Universe)
        self.dtu_url = "http://localhost:8001"

    async def prepare_task(
        self, task_data: Dict[str, Any], safety_mode: bool = True
    ) -> Dict[str, Any]:
        """
        Prepare a task for sandboxed execution.
        If safety_mode is True, routes API traffic to the Dark Twin Universe (DTU).
        """
        task_id = task_data.get("id") or f"task_{int(time.time())}"

        # Security: Inject Bastio and DTU environment variables
        env = {
            "BASTIO_API_KEY": os.environ.get("BASTIO_API_KEY", ""),
            "BASTIO_BASE_URL": os.environ.get(
                "BASTIO_BASE_URL", "https://api.bastio.com"
            ),
            "LOG_LEVEL": "DEBUG" if safety_mode else "INFO",
        }

        if safety_mode:
            self.logger.info(
                f"Task {task_id}: Safety Mode Active. Routing to Dark Twin Universe..."
            )
            # Route all tool-specific API calls to the DTU proxy
            env["DTU_PROXY_URL"] = os.environ.get("DTU_PROXY_URL", self.dtu_url)
            env["BASTIO_GATEWAY_MODE"] = "Shadow"
        else:
            self.logger.warning(
                f"Task {task_id}: Safety Mode Disabled. Proceeding with Live Execution."
            )
            env["DTU_PROXY_URL"] = ""
            env["BASTIO_GATEWAY_MODE"] = "Enforce"

        manifest = {
            "task_id": task_id,
            "environment": env,
            "quota": self.bastion.get_default_quota() if self.bastion else {},
            "data": task_data,
        }

        return manifest

    def dispatch_task(self, task_name: str, script_content: str, provider: str = "wsb"):
        """
        Prepares and launches a sandboxed task using the specified provider.
        """
        task_id = f"task_{int(time.time())}"
        task_dir = self.exchange_dir / task_id
        task_dir.mkdir(parents=True, exist_ok=True)

        # 1. Write the script to the mapped folder
        script_path = task_dir / "execute_me.py"
        with open(script_path, "w", encoding="utf-8") as f:
            f.write(script_content)

        # 2. Prepare the task manifest (Simulating async behavior for synchronous dispatch)
        # In a real async orchestrator, we would await self.prepare_task
        env = {
            "BASTIO_API_KEY": os.environ.get("BASTIO_API_KEY", "MOCK_KEY"),
            "BASTIO_BASE_URL": "https://api.bastio.com",
            "DTU_PROXY_URL": self.dtu_url if self.use_dtu else None,
            "OPENFANG_SECURITY_LEVEL": "STRICT",
        }

        manifest = {
            "task_id": task_id,
            "name": task_name,
            "provider": provider,
            "status": "QUEUED",
            "start_time": time.ctime(),
            "env": env,
        }
        with open(task_dir / "task.json", "w", encoding="utf-8") as f:
            json.dump(manifest, f, indent=2)

        print(f"[*] Task '{task_name}' dispatched via {provider} to {task_dir}")

        # 3. Trigger Provider
        process = None
        if provider == "wsb":
            # process = self._launch_wsb()
            pass
        elif provider == "sandboxie":
            process = self._launch_sandboxie(script_path)

        # 4. Register with Bastion for resource monitoring
        if process and self.bastion:
            self.bastion.register_process(process.pid)
            # Perform initial health check
            health = self.bastion.check_health()
            print(
                f"[*] Bastion Health: {health['status']} (CPU: {health['metrics']['system']['cpu']}%)"
            )

        return task_id

    def _launch_sandboxie(self, script_path: Path):
        """
        Launches the script using Sandboxie-Plus CLI (SbieCtrl.exe).
        Example: SbieCtrl.exe /box:OpenFang /start C:\Python312\python.exe C:\repos\openfang\exchange\sandbox\...\execute_me.py
        """
        # Note: Paths must be converted to host-visible paths for the Sandboxie process
        print(f"[*] Triggering Sandboxie-Plus for {script_path.name}")
        # subprocess.Popen(["C:\\Program Files\\Sandboxie-Plus\\SbieCtrl.exe", "/box:OpenFang", "/start", "python", str(script_path)])

    def poll_result(self, task_id: str, timeout: int = 300):
        """
        Polls for result.json in the task directory.
        """
        result_path = self.exchange_dir / task_id / "result.json"
        start_time = time.time()

        print(f"[*] Polling for results of task {task_id}...")
        while time.time() - start_time < timeout:
            if result_path.exists():
                with open(result_path, "r", encoding="utf-8") as f:
                    return json.load(f)
            time.sleep(5)

        return {"error": "Timeout", "status": "FAILED"}


if __name__ == "__main__":
    dispatcher = SandboxDispatcher("d:/dev/repos/openfang")
    # Sample Task: Verify server health within sandbox
    sample_script = "import os; print('Hello from Sandbox'); import json; with open('result.json', 'w') as f: json.dump({'status': 'SUCCESS', 'output': 'Sandbox Verified'}, f)"
    task_id = dispatcher.dispatch_task("Sandbox Health Check", sample_script)
    # result = dispatcher.poll_result(task_id) # Blocking poll
