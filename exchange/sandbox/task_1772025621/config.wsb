<Configuration>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>D:\Dev\repos\openfang</HostFolder>
      <SandboxFolder>C:\openfang</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>C:\Windows\System32\WindowsPowerShell\v1.0\powershell.exe -ExecutionPolicy Bypass -File C:\openfang\tools\provision_agent.ps1</Command>
  </LogonCommand>
</Configuration>