<Configuration>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>C:\temp_openfang</HostFolder>
      <SandboxFolder>C:\openfang</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>powershell.exe -ExecutionPolicy Bypass -Command "Write-Output 'Guest up on C drive' | Out-File C:\openfang\exchange\sandbox\diag_guest.log"</Command>
  </LogonCommand>
</Configuration>