<Configuration>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>D:\Dev\repos\openfang</HostFolder>
      <SandboxFolder>C:\openfang</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>powershell.exe -ExecutionPolicy Bypass -Command "Write-Output 'Guest started at $(Get-Date)' | Out-File C:\openfang\exchange\sandbox\diag_guest.log"</Command>
  </LogonCommand>
</Configuration>