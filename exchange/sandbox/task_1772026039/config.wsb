<Configuration>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>D:\Dev\repos\robofang</HostFolder>
      <SandboxFolder>C:\robofang</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>powershell.exe -ExecutionPolicy Bypass -Command "Add-Content -Path 'C:\robofang\exchange\sandbox\boot.log' -Value 'Guest up at $(Get-Date)'"</Command>
  </LogonCommand>
</Configuration>