<Configuration>
  <MappedFolders>
    <MappedFolder>
      <HostFolder>D:\Dev\repos\robofang</HostFolder>
      <SandboxFolder>C:\robofang</SandboxFolder>
      <ReadOnly>false</ReadOnly>
    </MappedFolder>
  </MappedFolders>
  <LogonCommand>
    <Command>cmd.exe /c "echo Guest Up > C:\robofang\exchange\sandbox\guest_up.log"</Command>
  </LogonCommand>
</Configuration>