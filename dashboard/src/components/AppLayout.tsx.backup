import React, { useState } from 'react';
import { NavLink, useLocation } from 'react-router-dom';
import {
    LayoutDashboard,
    Cpu,
    Settings,
    Activity,
    ChevronRight,
    ShieldCheck,
    UsersRound,
    ScrollText,
    Database,
    Clock,
    Sparkles,
    PanelLeftClose,
    Brain,
    Home,
    Palette,
    MonitorDot,
    Library
} from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';

const AppLayout: React.FC<{ children: React.ReactNode }> = ({ children }) => {
    const [isCollapsed, setIsCollapsed] = useState(false);
    const location = useLocation();

    const pathnames = location.pathname.split('/').filter((x) => x);

    return (
        <div className="flex h-screen w-screen bg-[#0a0a10] text-slate-200 selection:bg-indigo-500/30 noise-bg overflow-hidden relative">
            {/* Background Mesh */}
            <div className="fixed inset-0 pointer-events-none opacity-15 mix-blend-soft-light animate-mesh z-0" />

            {/* Sidebar */}
            <aside
                className={`flex flex-col border-r border-white/10 bg-[#0d0d16]/95 backdrop-blur-2xl transition-all duration-500 ease-[cubic-bezier(0.16,1,0.3,1)] z-40 relative ${isCollapsed ? 'w-[72px]' : 'w-[260px]'}`}
            >
                {/* Sidebar Header */}
                <div className="h-[72px] px-5 flex items-center justify-between border-b border-white/10" title="OpenFang Platform">
                    {!isCollapsed ? (
                        <motion.div
                            initial={{ opacity: 0, x: -10 }}
                            animate={{ opacity: 1, x: 0 }}
                            className="flex items-center gap-3"
                        >
                            <div className="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center shadow-lg shadow-indigo-600/30">
                                <Activity size={17} className="text-white" />
                            </div>
                            <span className="font-heading font-bold text-lg tracking-tight text-white">OpenFang</span>
                        </motion.div>
                    ) : (
                        <div className="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center mx-auto shadow-lg shadow-indigo-600/30">
                            <Activity size={17} className="text-white" />
                        </div>
                    )}
                </div>

                {/* Nav */}
                <nav className="flex-1 py-5 px-3 space-y-1 overflow-y-auto">
                    <NavItem to="/"            icon={<LayoutDashboard size={19} />} label="Dashboard"    isCollapsed={isCollapsed} active={location.pathname === '/'} />
                    <NavItem to="/council"     icon={<UsersRound size={19} />}      label="Council"      isCollapsed={isCollapsed} active={location.pathname === '/council'} />
                    <NavItem to="/fleet"       icon={<Cpu size={19} />}             label="Fleet"        isCollapsed={isCollapsed} active={location.pathname === '/fleet'} />
                    <NavItem to="/home"        icon={<Home size={19} />}            label="Home Hub"     isCollapsed={isCollapsed} active={location.pathname === '/home'} />
                    <NavItem to="/creative"    icon={<Palette size={19} />}         label="Creative Hub" isCollapsed={isCollapsed} active={location.pathname === '/creative'} />
                    <NavItem to="/infra"       icon={<MonitorDot size={19} />}      label="Infra Hub"    isCollapsed={isCollapsed} active={location.pathname === '/infra'} />
                    <NavItem to="/knowledge"   icon={<Database size={19} />}        label="Knowledge"    isCollapsed={isCollapsed} active={location.pathname === '/knowledge'} />
                    <NavItem to="/llm"         icon={<Brain size={19} />}           label="LLM"          isCollapsed={isCollapsed} active={location.pathname === '/llm'} />
                    <NavItem to="/logger"      icon={<ScrollText size={19} />}      label="Logger"       isCollapsed={isCollapsed} active={location.pathname === '/logger'} />
                    <NavItem to="/status"      icon={<ShieldCheck size={19} />}     label="Status"       isCollapsed={isCollapsed} active={location.pathname === '/status'} />
                    <NavItem to="/pulse"       icon={<Activity size={19} />}        label="Pulse Feed"   isCollapsed={isCollapsed} active={location.pathname === '/pulse'} />
                    <NavItem to="/timeline"    icon={<Clock size={19} />}           label="Timeline"     isCollapsed={isCollapsed} active={location.pathname === '/timeline'} />
                    <NavItem to="/kitchen-sink" icon={<Sparkles size={19} />}      label="Kitchen Sink" isCollapsed={isCollapsed} active={location.pathname === '/kitchen-sink'} />
                </nav>

                {/* Sidebar Footer */}
                <div className="p-3 border-t border-white/10 space-y-1">
                    <NavItem to="/settings" icon={<Settings size={19} />} label="Settings" isCollapsed={isCollapsed} active={location.pathname === '/settings'} />
                    <button
                        onClick={() => setIsCollapsed(!isCollapsed)}
                        className="w-full h-10 flex items-center justify-center rounded-xl bg-white/[0.05] border border-white/10 hover:bg-white/10 hover:border-white/20 transition-all group/toggle mt-1"
                        title={isCollapsed ? 'Expand Sidebar' : 'Collapse Sidebar'}
                    >
                        <PanelLeftClose
                            className={`text-slate-300 transition-transform duration-500 ${isCollapsed ? 'rotate-180' : ''}`}
                            size={17}
                        />
                    </button>
                    {!isCollapsed && (
                        <div className="mt-2 px-2 flex items-center justify-between">
                            <div className="flex flex-col">
                                <span className="text-[9px] font-bold text-slate-500 uppercase tracking-widest leading-none mb-1">Architecture</span>
                                <span className="text-[10px] font-mono text-slate-400">v0.9.4-SOTA</span>
                            </div>
                            <div className="flex items-center gap-1.5 px-2 py-0.5 rounded bg-emerald-500/15 border border-emerald-500/25">
                                <div className="w-1.5 h-1.5 rounded-full bg-emerald-400 shadow-[0_0_8px_rgba(52,211,153,0.6)] animate-pulse" />
                                <span className="text-[9px] font-bold text-emerald-400 uppercase tracking-tighter">Live</span>
                            </div>
                        </div>
                    )}
                </div>
            </aside>

            {/* Main Content */}
            <main className="flex-1 overflow-y-auto relative flex flex-col bg-transparent overflow-x-hidden z-10">
                {/* Topbar */}
                <header className="h-[72px] px-8 border-b border-white/10 flex items-center justify-between sticky top-0 backdrop-blur-2xl bg-[#0a0a10]/60 z-30">
                    <div className="flex items-center gap-3 text-sm font-sans">
                        <div className="flex items-center gap-2 text-slate-400">
                            <span className="text-[10px] font-bold uppercase tracking-widest cursor-pointer hover:text-slate-200 transition-colors">OpenFang</span>
                            <ChevronRight size={12} className="opacity-40" />
                        </div>
                        {pathnames.length === 0 ? (
                            <span className="font-bold text-slate-100 tracking-wide">Dashboard</span>
                        ) : (
                            <div className="flex items-center gap-2">
                                {pathnames.map((name, index) => {
                                    const routeTo = `/${pathnames.slice(0, index + 1).join('/')}`;
                                    const isLast = index === pathnames.length - 1;
                                    return (
                                        <div key={name} className="flex items-center gap-2">
                                            <NavLink
                                                to={routeTo}
                                                className={`capitalize transition-colors ${isLast ? 'font-bold text-slate-100 tracking-wide' : 'text-slate-400 hover:text-slate-200'}`}
                                            >
                                                {name.replace('-', ' ')}
                                            </NavLink>
                                            {!isLast && <ChevronRight size={12} className="opacity-40" />}
                                        </div>
                                    );
                                })}
                            </div>
                        )}
                    </div>

                    <div className="flex items-center gap-6 font-sans">
                        {/* Status pill */}
                        <div className="hidden md:flex items-center gap-6 px-5 py-2 bg-white/[0.05] border border-white/10 rounded-2xl">
                            <div className="flex items-center gap-2.5">
                                <div className="w-2 h-2 rounded-full bg-emerald-400 animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.6)]" />
                                <span className="text-[10px] font-bold text-slate-300 uppercase tracking-widest">Grid Active</span>
                            </div>
                            <div className="h-4 w-px bg-white/10" />
                            <div className="flex items-center gap-2.5">
                                <Cpu size={13} className="text-indigo-400" />
                                <span className="text-[10px] font-bold text-slate-300 uppercase tracking-widest">4 Clusters</span>
                            </div>
                        </div>

                        {/* Actions */}
                        <div className="flex items-center gap-3">
                            <NavLink
                                to="/settings"
                                className="p-2.5 rounded-xl hover:bg-white/8 border border-transparent hover:border-white/10 transition-all text-slate-300 group"
                                title="System Settings"
                            >
                                <Settings size={19} className="group-hover:rotate-45 transition-transform duration-500" />
                            </NavLink>
                            <button
                                className="w-9 h-9 rounded-xl bg-gradient-to-br from-indigo-500 to-purple-600 p-[1px] shadow-lg shadow-indigo-500/25 group cursor-pointer relative overflow-hidden"
                                title="Identity & Security"
                            >
                                <div className="w-full h-full rounded-[11px] bg-[#0d0d16] flex items-center justify-center overflow-hidden">
                                    <ShieldCheck size={18} className="text-indigo-300 group-hover:scale-110 transition-transform relative z-10" />
                                    <div className="absolute inset-0 bg-gradient-to-t from-indigo-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity" />
                                </div>
                            </button>
                        </div>
                    </div>
                </header>

                {/* Page Transitions */}
                <div className="flex-1 relative">
                    <AnimatePresence mode="wait">
                        <motion.div
                            key={location.pathname}
                            initial={{ opacity: 0, y: 20, scale: 0.99 }}
                            animate={{ opacity: 1, y: 0, scale: 1 }}
                            exit={{ opacity: 0, y: -20, scale: 0.99 }}
                            transition={{ duration: 0.35, ease: [0.16, 1, 0.3, 1] }}
                            className="p-8 pb-20 h-full"
                        >
                            {children}
                        </motion.div>
                    </AnimatePresence>
                </div>
            </main>
        </div>
    );
};

const NavItem: React.FC<{ to: string; icon: React.ReactNode; label: string; isCollapsed: boolean; active: boolean }> = ({
    to, icon, label, isCollapsed, active,
}) => (
    <NavLink
        to={to}
        className={`flex items-center gap-3.5 px-3.5 py-3 rounded-xl transition-all duration-200 group relative ${
            active
                ? 'bg-indigo-600/20 text-white border border-indigo-500/30'
                : 'text-slate-400 hover:text-slate-100 hover:bg-white/[0.06] border border-transparent'
        }`}
        title={label}
    >
        {active && (
            <motion.div
                layoutId="active-nav-glow"
                className="absolute inset-0 bg-indigo-500/8 rounded-xl"
            />
        )}
        <div className={`transition-all duration-300 shrink-0 ${active ? 'text-indigo-400 drop-shadow-[0_0_8px_rgba(99,102,241,0.6)]' : 'group-hover:text-slate-200'}`}>
            {icon}
        </div>
        {!isCollapsed && (
            <span className={`text-sm font-semibold tracking-wide whitespace-nowrap ${active ? 'text-white' : 'text-slate-400 group-hover:text-slate-100'}`}>
                {label}
            </span>
        )}
        {isCollapsed && (
            <div className="absolute left-full ml-3 px-2.5 py-1.5 bg-slate-800 backdrop-blur-md border border-white/15 rounded-lg text-[11px] font-semibold text-slate-100 opacity-0 group-hover:opacity-100 pointer-events-none transition-all translate-x-1 group-hover:translate-x-0 whitespace-nowrap z-50 shadow-xl">
                {label}
            </div>
        )}
    </NavLink>
);

export default AppLayout;
