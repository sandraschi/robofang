import React, { useState, useEffect, useCallback, useRef } from 'react';
import { motion, AnimatePresence } from 'framer-motion';
import {
    Activity, Database,
    Zap, RefreshCw, AlertTriangle,
    Clock, Radio, Server,
    WifiOff, RotateCcw,
} from 'lucide-react';
import { getSystem } from '../api';

// ── Types ─────────────────────────────────────────────────────────────────────

interface SystemData {
    status: string;
    service: string;
    version: string;
    pid: number;
    uptime_seconds: number;
    started_at: number;
    memory_mb: number;
    connectors: Record<string, { online: boolean; type: string }>;
    connectors_online: number;
    connectors_total: number;
}

type BridgeState = 'loading' | 'online' | 'offline' | 'error';

// ── Helpers ───────────────────────────────────────────────────────────────────

function formatUptime(seconds: number): string {
    if (seconds < 60) return `${seconds}s`;
    const m = Math.floor(seconds / 60) % 60;
    const h = Math.floor(seconds / 3600) % 24;
    const d = Math.floor(seconds / 86400);
    if (d > 0) return `${d}d ${h}h ${m}m`;
    if (h > 0) return `${h}h ${m}m`;
    return `${m}m ${seconds % 60}s`;
}

function formatTime(epoch: number): string {
    return new Date(epoch * 1000).toLocaleTimeString();
}

// ── Bridge Status Banner ──────────────────────────────────────────────────────

const BridgeBanner: React.FC<{
    state: BridgeState;
    errorMsg: string | null;
    lastSeen: Date | null;
    retrying: boolean;
    onRetry: () => void;
}> = ({ state, errorMsg, lastSeen, retrying, onRetry }) => {
    if (state === 'online') return null;

    return (
        <AnimatePresence>
            <motion.div
                initial={{ opacity: 0, y: -12 }}
                animate={{ opacity: 1, y: 0 }}
                exit={{ opacity: 0, y: -12 }}
                className="relative overflow-hidden rounded-2xl border border-red-500/30 bg-red-500/10 p-5"
            >
                {/* Pulsing background glow */}
                <div className="absolute inset-0 bg-gradient-to-r from-red-900/20 via-transparent to-transparent pointer-events-none" />

                <div className="relative flex flex-col sm:flex-row sm:items-center justify-between gap-4">
                    <div className="flex items-start gap-4">
                        <div className="mt-0.5 w-10 h-10 rounded-xl bg-red-500/20 border border-red-500/30 flex items-center justify-center shrink-0">
                            {state === 'loading' || retrying
                                ? <RefreshCw size={18} className="text-red-400 animate-spin" />
                                : <WifiOff size={18} className="text-red-400" />
                            }
                        </div>
                        <div>
                            <div className="text-base font-bold text-red-300">
                                {state === 'loading' ? 'Connecting to bridge…' : 'Bridge Unreachable'}
                            </div>
                            <div className="text-sm text-slate-400 mt-1">
                                {state === 'loading'
                                    ? 'Querying http://localhost:10865…'
                                    : errorMsg ?? 'Connection refused — is the bridge process running?'
                                }
                            </div>
                            {lastSeen && (
                                <div className="text-xs text-slate-500 mt-2 flex items-center gap-1.5">
                                    <Clock size={11} />
                                    Last seen online at {lastSeen.toLocaleTimeString()}
                                </div>
                            )}
                            {!lastSeen && state === 'offline' && (
                                <div className="text-xs text-slate-500 mt-2">
                                    Start the bridge: <code className="font-mono bg-white/[0.06] px-1.5 py-0.5 rounded text-red-300">cd robofang &amp;&amp; python -m robofang.main</code>
                                </div>
                            )}
                        </div>
                    </div>

                    <div className="flex gap-2 shrink-0">
                        <button
                            onClick={onRetry}
                            disabled={retrying || state === 'loading'}
                            className="flex items-center gap-2 px-4 py-2.5 bg-red-500/20 hover:bg-red-500/30 border border-red-500/40 hover:border-red-500/60 text-red-300 rounded-xl text-sm font-bold transition-all active:scale-95 disabled:opacity-50"
                        >
                            <RotateCcw size={14} className={retrying ? 'animate-spin' : ''} />
                            {retrying ? 'Retrying…' : 'Retry Connection'}
                        </button>
                    </div>
                </div>
            </motion.div>
        </AnimatePresence>
    );
};

// ── Metric Card ───────────────────────────────────────────────────────────────

const MetricCard: React.FC<{
    label: string;
    value: string;
    sub?: string;
    icon: React.ReactNode;
    color: string; // tailwind token e.g. "emerald"
    live?: boolean;
}> = ({ label, value, sub, icon, color, live }) => {
    const COLOR: Record<string, string> = {
        emerald: 'bg-emerald-500/10 text-emerald-400 border-emerald-500/20',
        blue:    'bg-blue-500/10 text-blue-400 border-blue-500/20',
        purple:  'bg-purple-500/10 text-purple-400 border-purple-500/20',
        amber:   'bg-amber-500/10 text-amber-400 border-amber-500/20',
        red:     'bg-red-500/10 text-red-400 border-red-500/20',
        slate:   'bg-slate-500/10 text-slate-400 border-slate-500/20',
    };
    return (
        <div className="bg-[#16162a] border border-white/10 p-5 rounded-2xl flex items-start justify-between hover:border-white/20 transition-colors">
            <div className="space-y-1">
                <div className="flex items-center gap-1.5">
                    <span className="text-[10px] font-mono text-slate-400 uppercase tracking-widest">{label}</span>
                    {live && <span className="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" />}
                </div>
                <h3 className="text-2xl font-bold text-white">{value}</h3>
                {sub && <div className="text-xs text-slate-400 font-mono">{sub}</div>}
            </div>
            <div className={`p-3 rounded-xl border ${COLOR[color] ?? COLOR.slate}`}>
                {icon}
            </div>
        </div>
    );
};

// ── Connector Row ─────────────────────────────────────────────────────────────

const ConnectorRow: React.FC<{ name: string; info: { online: boolean; type: string } }> = ({ name, info }) => (
    <tr className="hover:bg-white/[0.03] transition-colors">
        <td className="px-6 py-3.5">
            <div className="flex items-center gap-3">
                <div className="p-1.5 rounded-lg bg-white/[0.06] text-slate-400">
                    <Radio size={13} />
                </div>
                <span className="font-medium text-slate-100 text-sm">{name.replace(/-/g, ' ').replace(/\b\w/g, c => c.toUpperCase())}</span>
            </div>
        </td>
        <td className="px-6 py-3.5">
            <div className="text-[10px] font-mono text-slate-500 uppercase">{info.type}</div>
        </td>
        <td className="px-6 py-3.5">
            {info.online ? (
                <span className="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-widest bg-emerald-500/15 text-emerald-400 border border-emerald-500/25">
                    <span className="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" />
                    Online
                </span>
            ) : (
                <span className="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-widest bg-slate-500/15 text-slate-400 border border-slate-500/20">
                    <span className="w-1.5 h-1.5 rounded-full bg-slate-600" />
                    Offline
                </span>
            )}
        </td>
    </tr>
);

// ── Main ──────────────────────────────────────────────────────────────────────

const POLL_INTERVAL = 5000; // ms

const Status: React.FC = () => {
    const [bridgeState, setBridgeState] = useState<BridgeState>('loading');
    const [data, setData] = useState<SystemData | null>(null);
    const [errorMsg, setErrorMsg] = useState<string | null>(null);
    const [lastSeen, setLastSeen] = useState<Date | null>(null);
    const [lastPolled, setLastPolled] = useState<Date | null>(null);
    const [retrying, setRetrying] = useState(false);
    const pollRef = useRef<ReturnType<typeof setInterval> | null>(null);

    const poll = useCallback(async (isManual = false) => {
        if (isManual) setRetrying(true);
        try {
            const result: SystemData = await getSystem();
            setData(result);
            setBridgeState('online');
            setErrorMsg(null);
            setLastSeen(new Date());
        } catch (e: any) {
            const msg = e?.code === 'ECONNREFUSED' || e?.message?.includes('Network Error')
                ? 'Connection refused — bridge is not running on port 10865.'
                : e?.message ?? 'Unknown error';
            setErrorMsg(msg);
            setBridgeState(bridgeState === 'online' ? 'offline' : (bridgeState === 'loading' ? 'offline' : bridgeState));
            // Don't wipe last data — keep it visible as "stale"
        } finally {
            setLastPolled(new Date());
            if (isManual) setRetrying(false);
        }
    }, [bridgeState]);

    // Initial poll + interval
    useEffect(() => {
        poll();
        pollRef.current = setInterval(() => poll(), POLL_INTERVAL);
        return () => { if (pollRef.current) clearInterval(pollRef.current); };
    }, []); // eslint-disable-line react-hooks/exhaustive-deps

    const handleRetry = () => poll(true);

    const isStale = bridgeState === 'offline' && data !== null;

    return (
        <div className="max-w-7xl mx-auto space-y-6">

            {/* Header */}
            <header className="flex items-center justify-between">
                <div>
                    <h1 className="text-3xl font-bold text-white tracking-tight flex items-center gap-3">
                        <Activity className="text-emerald-400" />
                        System Status
                    </h1>
                    <p className="text-slate-300 mt-1 text-sm">
                        Live bridge health and connector states.
                        {lastPolled && (
                            <span className="text-slate-500 ml-2 font-mono text-xs">
                                Last polled {lastPolled.toLocaleTimeString()}
                            </span>
                        )}
                    </p>
                </div>

                <div className="flex items-center gap-3">
                    {/* Manual refresh */}
                    <button
                        onClick={handleRetry}
                        disabled={retrying}
                        className="flex items-center gap-2 px-4 py-2 bg-white/[0.06] hover:bg-white/10 border border-white/10 hover:border-white/20 text-slate-200 rounded-xl text-xs font-bold uppercase tracking-wider transition-all active:scale-95 disabled:opacity-50"
                    >
                        <RefreshCw size={13} className={retrying ? 'animate-spin' : ''} />
                        Refresh
                    </button>

                    {/* Global status pill */}
                    {bridgeState === 'online' ? (
                        <div className="flex items-center gap-2 px-3 py-1.5 bg-emerald-400/10 border border-emerald-400/25 rounded-full">
                            <div className="w-2 h-2 bg-emerald-400 rounded-full animate-pulse shadow-[0_0_8px_rgba(52,211,153,0.6)]" />
                            <span className="text-[10px] font-bold text-emerald-400 uppercase tracking-widest">Bridge Online</span>
                        </div>
                    ) : bridgeState === 'loading' ? (
                        <div className="flex items-center gap-2 px-3 py-1.5 bg-amber-400/10 border border-amber-400/25 rounded-full">
                            <RefreshCw size={11} className="text-amber-400 animate-spin" />
                            <span className="text-[10px] font-bold text-amber-400 uppercase tracking-widest">Connecting</span>
                        </div>
                    ) : (
                        <div className="flex items-center gap-2 px-3 py-1.5 bg-red-400/10 border border-red-400/25 rounded-full">
                            <div className="w-2 h-2 bg-red-400 rounded-full" />
                            <span className="text-[10px] font-bold text-red-400 uppercase tracking-widest">Bridge Down</span>
                        </div>
                    )}
                </div>
            </header>

            {/* Bridge down / connecting banner */}
            {bridgeState !== 'online' && (
                <BridgeBanner
                    state={bridgeState}
                    errorMsg={errorMsg}
                    lastSeen={lastSeen}
                    retrying={retrying}
                    onRetry={handleRetry}
                />
            )}

            {/* Stale data warning strip */}
            {isStale && (
                <div className="flex items-center gap-2 px-4 py-2.5 bg-amber-500/10 border border-amber-500/25 rounded-xl text-xs text-amber-300">
                    <AlertTriangle size={13} />
                    Showing last known data from {lastSeen?.toLocaleTimeString()} — bridge is currently unreachable.
                </div>
            )}

            {/* Metric tiles — only shown when data available */}
            {data && (
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                    <MetricCard
                        label="Bridge Uptime"
                        value={formatUptime(data.uptime_seconds)}
                        sub={`Started ${formatTime(data.started_at)}`}
                        icon={<Zap size={20} />}
                        color="emerald"
                        live={bridgeState === 'online'}
                    />
                    <MetricCard
                        label="Memory"
                        value={`${data.memory_mb} MB`}
                        sub="Bridge process RSS"
                        icon={<Database size={20} />}
                        color="blue"
                        live={bridgeState === 'online'}
                    />
                    <MetricCard
                        label="Connectors"
                        value={`${data.connectors_online} / ${data.connectors_total}`}
                        sub="Online / Total"
                        icon={<Radio size={20} />}
                        color={data.connectors_online > 0 ? 'emerald' : 'red'}
                        live={bridgeState === 'online'}
                    />
                    <MetricCard
                        label="PID"
                        value={String(data.pid)}
                        sub={`v${data.version}`}
                        icon={<Server size={20} />}
                        color="purple"
                        live={bridgeState === 'online'}
                    />
                </div>
            )}

            {/* Empty state when bridge never connected */}
            {!data && bridgeState !== 'loading' && (
                <div className="flex flex-col items-center justify-center py-20 gap-4 text-slate-500">
                    <WifiOff size={40} className="opacity-30" />
                    <div className="text-sm">No data — bridge has not responded yet.</div>
                    <button
                        onClick={handleRetry}
                        className="flex items-center gap-2 px-5 py-2.5 bg-indigo-500/20 hover:bg-indigo-500/30 border border-indigo-500/35 text-indigo-300 rounded-xl text-sm font-bold transition-all"
                    >
                        <RotateCcw size={14} />
                        Try Again
                    </button>
                </div>
            )}

            {/* Loading skeleton */}
            {!data && bridgeState === 'loading' && (
                <div className="flex items-center justify-center py-20 text-slate-500 gap-3">
                    <RefreshCw size={18} className="animate-spin" />
                    <span className="text-sm">Querying bridge on localhost:10865…</span>
                </div>
            )}

            {/* Connector table */}
            {data && Object.keys(data.connectors).length > 0 && (
                <div className="space-y-4">
                    <h2 className="text-lg font-bold text-white flex items-center gap-2">
                        <Radio size={18} className="text-indigo-400" />
                        Registered Connectors
                        <span className="text-sm font-normal text-slate-500 ml-1">
                            — {data.connectors_online} online, {data.connectors_total - data.connectors_online} offline
                        </span>
                    </h2>
                    <div className="bg-[#16162a] border border-white/10 rounded-2xl overflow-hidden">
                        <table className="w-full text-left border-collapse">
                            <thead className="bg-white/[0.03] border-b border-white/10 text-[10px] font-mono text-slate-400 uppercase tracking-widest">
                                <tr>
                                    <th className="px-6 py-3 font-medium">Connector</th>
                                    <th className="px-6 py-3 font-medium">Type</th>
                                    <th className="px-6 py-3 font-medium">Status</th>
                                </tr>
                            </thead>
                            <tbody className="divide-y divide-white/[0.06]">
                                {Object.entries(data.connectors)
                                    .sort(([, a], [, b]) => Number(b.online) - Number(a.online))
                                    .map(([name, info]) => (
                                        <ConnectorRow key={name} name={name} info={info} />
                                    ))
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            )}
        </div>
    );
};

export default Status;
