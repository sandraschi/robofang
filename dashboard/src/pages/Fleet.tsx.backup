const ConnectorCard = ({ name, status, type }: { name: string, status: 'online' | 'offline', type: string }) => (
    <motion.div
        whileHover={{ y: -2 }}
        className="page-card p-4 flex items-center justify-between group hover:border-indigo-500/30 transition-all cursor-pointer bg-white/[0.02]"
    >
        <div className="flex items-center gap-4">
            <div className={`w-12 h-12 rounded-xl flex items-center justify-center transition-colors ${status === 'online' ? 'bg-emerald-500/10 text-emerald-500 border border-emerald-500/20' : 'bg-slate-800/50 text-slate-600 border border-white/5'
                }`}>
                <Cpu size={20} />
            </div>
            <div>
                <h4 className="text-sm font-bold text-white group-hover:text-indigo-400 transition-colors">{name}</h4>
                <p className="text-[10px] text-slate-500 uppercase tracking-widest font-bold mt-0.5">{type}</p>
            </div>
        </div>
        <div className="flex flex-col items-end gap-2">
            <div className={`w-2 h-2 rounded-full ${status === 'online' ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]' : 'bg-slate-700'}`} />
            <Power size={14} className={status === 'online' ? 'text-emerald-500/40' : 'text-slate-800'} />
        </div>
    </motion.div>
);

const PulseItem = ({ time, text, type }: { time: string, text: string, type: 'success' | 'info' | 'warning' }) => (
    <div className="flex gap-4 group">
        <span className="text-[10px] font-mono text-slate-600 mt-1 shrink-0 font-bold">{time}</span>
        <div className="flex flex-col min-w-0">
            <div className="flex items-center gap-3">
                <div className={`w-2 h-2 rounded-full shrink-0 ${type === 'success' ? 'bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.4)]' :
                    type === 'warning' ? 'bg-amber-500 shadow-[0_0_8px_rgba(245,158,11,0.4)]' :
                        'bg-indigo-500 shadow-[0_0_8px_rgba(99,102,241,0.4)]'
                    }`} />
                <p className="text-sm text-slate-300 leading-relaxed group-hover:text-white transition-colors truncate">{text}</p>
            </div>
        </div>
    </div>
);

const PersonaAttr = ({ label, value }: { label: string, value: string }) => (
    <div className="flex justify-between items-center py-2.5 border-b border-white/5 last:border-0 hover:bg-white/[0.01] px-2 rounded-lg transition-colors">
        <span className="text-[11px] text-slate-500 font-bold uppercase tracking-wider">{label}</span>
        <span className="text-[11px] font-bold text-white font-mono">{value}</span>
    </div>
);

export default Fleet;
