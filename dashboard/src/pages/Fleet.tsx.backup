import {
    Cpu,
    Power,
    UserCheck,
    ShieldAlert,
    Globe,
    ShieldCheck,
    Settings2,
    Plus,
    Activity
} from 'lucide-react';

const Fleet: React.FC = () => {
    return (
        <div className="page-grid">
            <div className="lg:col-span-12 mb-2 flex flex-col md:flex-row md:items-center justify-between gap-4">
                <div>
                    <h1 className="text-3xl font-bold text-white font-heading">Fleet Control</h1>
                    <p className="text-slate-400 text-sm mt-1">Manage sovereign connectors and autonomous agents.</p>
                </div>
                <div className="flex items-center gap-3">
                    <button
                        title="Add New Connector"
                        className="flex items-center gap-2 px-4 py-2 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl text-xs font-bold uppercase tracking-wider shadow-lg shadow-indigo-600/20 transition-all active:scale-95"
                    >
                        <Plus size={14} /> New Connector
                    </button>
                    <button
                        title="Fleet Settings"
                        className="p-2 bg-white/5 hover:bg-white/10 border border-white/5 rounded-xl transition-all active:scale-95"
                    >
                        <Settings2 size={18} className="text-slate-400" />
                    </button>
                </div>
            </div>

            <div className="lg:col-span-8 space-y-6">
                <div className="page-card flex flex-col p-0 overflow-hidden">
                    <div className="card-header border-b border-white/5 p-6 flex items-center justify-between bg-white/[0.02]">
                        <h2 className="card-title flex items-center gap-3">
                            <Globe size={20} className="text-indigo-400" />
                            Universal Connectors
                        </h2>
                        <span className="text-[10px] font-bold text-slate-500 uppercase bg-white/5 px-2 py-1 rounded border border-white/5">2 Active / 7 Total</span>
                    </div>
                    <div className="p-6 grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <ConnectorCard name="Resonite" status="online" type="industrial" />
                        <ConnectorCard name="Moltbook" status="online" type="log-adn" />
                        <ConnectorCard name="Discord" status="offline" type="social" />
                        <ConnectorCard name="WhatsApp" status="offline" type="mobile" />
                        <ConnectorCard name="Teams" status="offline" type="enterprise" />
                        <ConnectorCard name="Zoom" status="offline" type="meeting" />
                    </div>
                </div>

                <div className="page-card flex flex-col p-0 overflow-hidden">
                    <div className="card-header border-b border-white/5 p-6">
                        <h2 className="card-title flex items-center gap-3">
                            <Activity size={20} className="text-pink-400" />
                            Pulse Reflection
                        </h2>
                    </div>
                    <div className="p-6 space-y-5">
                        <PulseItem time="17:42" text="System reflection recorded to ADN: Fleet state stable." type="success" />
                        <PulseItem time="17:30" text="Syncing 24 files with local knowledge engine." type="info" />
                        <PulseItem time="17:15" text="External skill discovery found 12 legacy modules." type="warning" />
                    </div>
                </div>
            </div>

            <div className="lg:col-span-4 space-y-6">
                <div className="page-card flex flex-col p-0 overflow-hidden bg-gradient-to-br from-emerald-500/[0.03] to-transparent">
                    <div className="card-header border-b border-white/5 p-6">
                        <h2 className="card-title flex items-center gap-3">
                            <UserCheck size={20} className="text-emerald-400" />
                            Active Persona
                        </h2>
                    </div>
                    <div className="p-8 flex flex-col items-center text-center">
                        <div className="w-24 h-24 rounded-3xl bg-emerald-500/10 border border-emerald-500/20 flex items-center justify-center text-emerald-500 mb-6 shadow-2xl shadow-emerald-500/10 group-hover:scale-105 transition-transform duration-500">
                            <ShieldCheck size={48} strokeWidth={1.5} />
