                        <h3 className="text-2xl font-bold text-white mb-1">Sovereign</h3>
                        <p className="text-slate-500 text-xs font-medium uppercase tracking-widest px-3 py-1 bg-white/5 rounded-full mt-2">Primary Adjudicator</p>

                        <div className="w-full space-y-3 mt-8">
                            <PersonaAttr label="Logic Level" value="Industrial" />
                            <PersonaAttr label="Directness" value="Maximum" />
                            <PersonaAttr label="Tone" value="Reductionist" />
