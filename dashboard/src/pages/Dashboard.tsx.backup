import React, { useState, useEffect, useRef } from 'react';
import { Send, Zap, Brain, Sparkles, User } from 'lucide-react';
import { motion, AnimatePresence } from 'framer-motion';
import { askQuestion } from '../api';

interface Message {
    id: string;
    role: 'user' | 'agent';
    content: string;
    timestamp: Date;
    model?: string;
}

const Dashboard: React.FC = () => {
    const [messages, setMessages] = useState<Message[]>([]);
    const [input, setInput] = useState('');
    const [isLoading, setIsLoading] = useState(false);
    const scrollRef = useRef<HTMLDivElement>(null);

    useEffect(() => {
        if (scrollRef.current) {
            scrollRef.current.scrollTop = scrollRef.current.scrollHeight;
        }
    }, [messages]);

    const handleSend = async () => {
        if (!input.trim() || isLoading) return;

        const userMsg: Message = {
            id: Date.now().toString(),
            role: 'user',
            content: input,
            timestamp: new Date()
        };

        setMessages(prev => [...prev, userMsg]);
        setInput('');
        setIsLoading(true);

        try {
            const response = await askQuestion(input);
            const agentMsg: Message = {
                id: (Date.now() + 1).toString(),
                role: 'agent',
                content: response.message,
                timestamp: new Date(),
                model: response.data?.model || 'Cortex-SOTA'
            };
            setMessages(prev => [...prev, agentMsg]);
        } catch (error) {
            console.error('Failed to ask:', error);
            const errorMsg: Message = {
                id: (Date.now() + 1).toString(),
                role: 'agent',
                content: "CRITICAL FAILURE: Neural bridge link severed. Check industrial backbone status.",
                timestamp: new Date(),
                model: 'SYSTEM'
            };
            setMessages(prev => [...prev, errorMsg]);
        } finally {
            setIsLoading(false);
        }
    };

    return (
        <div className="flex flex-col h-[calc(100vh-140px)] max-w-6xl mx-auto font-sans relative">
            {/* Header / Sub-topbar */}
            <div className="flex items-center justify-between mb-8">
                <div className="flex flex-col">
                    <h1 className="text-3xl font-heading font-bold text-white tracking-tight flex items-center gap-3">
                        <Brain className="text-indigo-500" size={28} />
                        Sovereign Reasoning
                    </h1>
                    <p className="text-slate-500 text-sm mt-1 font-medium">Hyper-threaded orchestration for high-level agentic directives.</p>
                </div>
                <div className="flex items-center gap-3">
                    <div className="px-4 py-2 rounded-xl bg-white/[0.03] border border-white/[0.05] flex items-center gap-3">
                        <div className="w-2 h-2 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]" />
                        <span className="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Core Stable</span>
                    </div>
                </div>
            </div>

            {/* Chat Container */}
            <div className="flex-1 flex flex-col page-card p-0 overflow-hidden relative border-white/[0.04]">
                <div className="absolute inset-0 bg-gradient-to-b from-indigo-500/[0.02] to-transparent pointer-events-none" />

                {/* Messages Area */}
                <div
                    ref={scrollRef}
                    className="flex-1 overflow-y-auto px-8 py-10 space-y-10 custom-scrollbar relative z-10"
                >
                    <AnimatePresence>
                        {messages.length === 0 && (
                            <motion.div
                                initial={{ opacity: 0, scale: 0.95 }}
                                animate={{ opacity: 1, scale: 1 }}
                                className="h-full flex flex-col items-center justify-center text-center px-12"
                            >
                                <div className="w-24 h-24 rounded-3xl bg-indigo-600/10 border border-indigo-500/20 flex items-center justify-center mb-6 shadow-2xl shadow-indigo-500/10 animate-pulse">
                                    <Sparkles className="text-indigo-400" size={40} />
                                </div>
                                <h2 className="text-2xl font-heading font-bold text-white mb-3">Awaiting Command</h2>
                                <p className="text-slate-500 max-w-sm leading-relaxed text-sm">
                                    The Council is standing by for high-priority directives. Initialize the reasoning stream with your inquiry.
                                </p>
                            </motion.div>
                        )}

                        {messages.map((msg) => (
                            <motion.div
                                key={msg.id}
                                initial={{ opacity: 0, y: 20 }}
                                animate={{ opacity: 1, y: 0 }}
                                className={`flex items-start gap-4 ${msg.role === 'user' ? 'flex-row-reverse' : ''}`}
                            >
                                {/* Avatar */}
                                <div className={`w-10 h-10 rounded-xl flex items-center justify-center shrink-0 shadow-lg relative z-10 ${msg.role === 'user'
                                    ? 'bg-slate-800 border border-white/10'
                                    : 'bg-indigo-600 shadow-indigo-600/20 shadow-xl'
                                    }`}
                                    title={msg.role === 'user' ? 'Executive Avatar' : `${msg.model} Avatar`}
                                >
                                    {msg.role === 'user' ? <User size={20} className="text-slate-300" /> : <Zap size={20} className="text-white" />}
                                    {msg.role === 'agent' && (
                                        <div className="absolute -bottom-1 -right-1 w-4 h-4 bg-emerald-500 rounded-full border-2 border-[#09090b] flex items-center justify-center">
                                            <div className="w-1.5 h-1.5 bg-white rounded-full animate-ping" />
                                        </div>
                                    )}
                                </div>

                                {/* Message Bubble */}
                                <div className={`flex flex-col group max-w-[85%] ${msg.role === 'user' ? 'items-end' : 'items-start'}`}>
                                    <div className={`flex items-center gap-3 mb-2 px-1`}>
                                        <span className={`text-[10px] font-bold uppercase tracking-widest ${msg.role === 'user' ? 'text-slate-400' : 'text-indigo-400'}`}>
                                            {msg.role === 'user' ? 'Executive' : msg.model}
                                        </span>
                                        <span className="w-1 h-1 rounded-full bg-slate-800" />
                                        <span className="text-[10px] font-mono text-slate-600">
                                            {msg.timestamp.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                                        </span>
                                    </div>

                                    <div className={`relative p-5 rounded-2xl transition-all duration-300 ${msg.role === 'user'
                                        ? 'bg-indigo-600/10 text-slate-200 border border-indigo-500/20 rounded-tr-none hover:bg-indigo-600/20'
                                        : 'bg-white/[0.03] text-slate-300 border border-white/[0.05] rounded-tl-none hover:bg-white/[0.05] hover:border-white/[0.08]'
                                        }`}>
                                        <div className="text-sm font-medium leading-relaxed whitespace-pre-wrap select-text">
                                            {msg.content}
                                        </div>

                                        {/* Dynamic Glow for User Messages */}
                                        {msg.role === 'user' && (
                                            <div className="absolute -inset-[1px] bg-gradient-to-br from-indigo-500/20 to-purple-500/20 rounded-2xl rounded-tr-none -z-10 opacity-0 group-hover:opacity-100 transition-opacity blur-sm" />
                                        )}
                                    </div>
                                </div>
                            </motion.div>
                        ))}

                        {isLoading && (
                            <motion.div
                                initial={{ opacity: 0, x: -10 }}
                                animate={{ opacity: 1, x: 0 }}
                                className="flex items-start gap-4"
                            >
                                <div className="w-10 h-10 rounded-xl bg-indigo-600 flex items-center justify-center shrink-0 shadow-lg shadow-indigo-600/10 animate-pulse">
                                    <Sparkles size={20} className="text-white" />
                                </div>
                                <div className="flex flex-col gap-2">
                                    <div className="flex items-center gap-2 mb-1 px-1">
                                        <span className="text-[10px] font-bold uppercase tracking-widest text-indigo-400">Processing...</span>
                                    </div>
                                    <div className="bg-white/[0.03] border border-white/[0.05] rounded-2xl rounded-tl-none px-6 py-4 flex gap-2">
                                        <div className="w-1.5 h-1.5 rounded-full bg-indigo-500/50 animate-bounce [animation-delay:-0.3s]" />
                                        <div className="w-1.5 h-1.5 rounded-full bg-indigo-500/50 animate-bounce [animation-delay:-0.15s]" />
                                        <div className="w-1.5 h-1.5 rounded-full bg-indigo-500/50 animate-bounce" />
                                    </div>
                                </div>
                            </motion.div>
                        )}
                    </AnimatePresence>
                </div>

                {/* Input Area */}
                <div className="px-8 py-8 border-t border-white/[0.04] bg-white/[0.01] relative z-20">
                    <div className="relative group max-w-4xl mx-auto">
                        <div className="absolute -inset-1 bg-gradient-to-r from-indigo-500/20 via-purple-500/20 to-indigo-500/20 rounded-2xl blur-lg opacity-0 group-focus-within:opacity-100 transition-all duration-700 animate-pulse" />
                        <div className="relative flex items-center bg-[#0d0d12] border border-white/[0.08] p-2 pl-4 rounded-2xl shadow-2xl focus-within:border-indigo-500/50 transition-all">
                            <input
                                type="text"
                                value={input}
                                onChange={(e) => setInput(e.target.value)}
                                onKeyDown={(e) => e.key === 'Enter' && handleSend()}
                                placeholder="Issue an executive directive..."
                                title="Executive Directive Input"
                                className="flex-1 bg-transparent border-none outline-none py-2 text-sm text-white placeholder-slate-600 focus:ring-0 font-medium"
                            />
                            <div className="flex items-center gap-2">
                                <button
                                    className="p-2 text-slate-500 hover:text-indigo-400 transition-colors hidden sm:flex"
                                    title="Attach Context"
                                >
                                    <Sparkles size={20} />
                                </button>
                                <button
                                    onClick={handleSend}
                                    disabled={isLoading || !input.trim()}
                                    className={`p-3 rounded-xl transition-all duration-300 flex items-center justify-center shadow-lg ${isLoading || !input.trim()
                                        ? 'bg-slate-800 text-slate-500 grayscale opacity-50 cursor-not-allowed'
                                        : 'bg-indigo-600 text-white hover:bg-indigo-500 shadow-indigo-600/25 active:scale-95'
                                        }`}
                                    title="Transmit Directive"
                                >
                                    <Send size={18} />
                                </button>
                            </div>
                        </div>
                    </div>
                    <div className="mt-4 flex justify-center gap-6">
                        <span className="text-[10px] font-bold text-slate-600 uppercase tracking-[0.2em]">End-to-End Orchestration</span>
                        <span className="text-[10px] font-bold text-slate-600 uppercase tracking-[0.2em]">•</span>
                        <span className="text-[10px] font-bold text-slate-600 uppercase tracking-[0.2em]">Neural Backbone v4.2</span>
                    </div>
                </div>
            </div>
        </div>
    );
};


export default Dashboard;
