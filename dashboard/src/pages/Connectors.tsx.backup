import React from 'react';
import { motion } from 'framer-motion';
import { PlugZap, CheckCircle2, AlertCircle, RefreshCw, Terminal, Search } from 'lucide-react';

const Connectors: React.FC = () => {
    const servers = [
        { name: 'memops', type: 'Knowledge', status: 'online', tools: 24, latency: '42ms' },
        { name: 'fileops', type: 'System', status: 'online', tools: 48, latency: '12ms' },
        { name: 'brightdata', type: 'Research', status: 'connected', tools: 12, latency: '156ms' },
        { name: 'robotics-mcp', type: 'Hardware', status: 'degraded', tools: 8, latency: '890ms' },
        { name: 'unity-bridge', type: 'Virtual', status: 'offline', tools: 5, latency: '-' },
    ];

    return (
        <div className="space-y-8">
            <div className="flex items-center justify-between">
                <div className="flex flex-col gap-2">
                    <h1 className="text-3xl font-bold text-white font-heading">Connector Registry</h1>
                    <p className="text-slate-400">Manage federated MCP servers and sovereign toolsets.</p>
                </div>
                <div className="flex gap-3">
                    <div className="relative">
                        <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-500" size={16} />
                        <input
                            type="text"
                            placeholder="Search connectors..."
                            className="pl-10 pr-4 py-2 bg-white/5 border border-white/10 rounded-xl text-sm focus:outline-none focus:border-indigo-500/50 transition-colors w-64"
                        />
                    </div>
                    <button className="flex items-center gap-2 px-4 py-2 bg-indigo-600 rounded-xl text-white text-sm font-bold hover:bg-indigo-500 transition-colors shadow-lg shadow-indigo-500/20">
                        <RefreshCw size={16} />
                        Refresh All
                    </button>
                </div>
            </div>

            <div className="glass-panel bg-white/5 border-white/10 rounded-3xl overflow-hidden">
                <table className="w-full text-left">
                    <thead>
                        <tr className="border-b border-white/5 bg-white/2">
                            <th className="px-8 py-5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Connector Name</th>
                            <th className="px-8 py-5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Domain</th>
                            <th className="px-8 py-5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Status</th>
                            <th className="px-8 py-5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Tools</th>
                            <th className="px-8 py-5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Latency</th>
                            <th className="px-8 py-5 text-[10px] font-bold uppercase tracking-widest text-slate-500">Actions</th>
                        </tr>
                    </thead>
                    <tbody className="divide-y divide-white/5">
                        {servers.map((server, idx) => (
                            <motion.tr
                                key={server.name}
                                initial={{ opacity: 0, y: 10 }}
                                animate={{ opacity: 1, y: 0 }}
                                transition={{ delay: idx * 0.05 }}
                                className="group hover:bg-white/2 transition-colors"
                            >
                                <td className="px-8 py-4">
                                    <div className="flex items-center gap-3">
                                        <div className="p-2 rounded-lg bg-indigo-500/10 text-indigo-400">
                                            <PlugZap size={16} />
                                        </div>
                                        <span className="text-sm font-bold text-white font-mono">{server.name}</span>
                                    </div>
                                </td>
                                <td className="px-8 py-4">
                                    <span className="text-xs text-slate-400">{server.type}</span>
                                </td>
                                <td className="px-8 py-4">
                                    <div className="flex items-center gap-2">
                                        {server.status === 'online' || server.status === 'connected' ? (
                                            <CheckCircle2 size={14} className="text-emerald-500" />
                                        ) : server.status === 'degraded' ? (
                                            <AlertCircle size={14} className="text-amber-500" />
                                        ) : (
                                            <AlertCircle size={14} className="text-rose-500" />
                                        )}
                                        <span className={`text-[10px] font-bold uppercase tracking-wider ${server.status === 'online' || server.status === 'connected' ? 'text-emerald-500' :
                                                server.status === 'degraded' ? 'text-amber-500' : 'text-rose-500'
                                            }`}>
                                            {server.status}
                                        </span>
                                    </div>
                                </td>
                                <td className="px-8 py-4">
                                    <span className="text-xs text-slate-300 font-mono">{server.tools} tools</span>
                                </td>
                                <td className="px-8 py-4">
                                    <span className="text-xs text-slate-500 font-mono">{server.latency}</span>
                                </td>
                                <td className="px-8 py-4">
                                    <div className="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button title="Logs" className="p-2 rounded-lg hover:bg-white/10 text-slate-400 hover:text-white transition-colors">
                                            <Terminal size={16} />
                                        </button>
                                        <button title="Restart" className="p-2 rounded-lg hover:bg-white/10 text-slate-400 hover:text-indigo-400 transition-colors">
                                            <RefreshCw size={16} />
                                        </button>
                                    </div>
                                </td>
                            </motion.tr>
                        ))}
                    </tbody>
                </table>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div className="glass-panel p-6 bg-emerald-500/5 border-emerald-500/20 rounded-2xl flex flex-col gap-2">
                    <h3 className="text-sm font-bold text-emerald-500 uppercase tracking-widest">Federation Health</h3>
                    <div className="flex items-end gap-3 mt-2">
                        <span className="text-4xl font-bold text-white font-mono">94.2%</span>
                        <span className="text-xs text-emerald-500 mb-1 font-medium">+2.1% from baseline</span>
                    </div>
                </div>
                <div className="glass-panel p-6 bg-indigo-500/5 border-indigo-500/20 rounded-2xl flex flex-col gap-2">
                    <h3 className="text-sm font-bold text-indigo-500 uppercase tracking-widest">Active Tool Calls</h3>
                    <div className="flex items-end gap-3 mt-2">
                        <span className="text-4xl font-bold text-white font-mono">1,482</span>
                        <span className="text-xs text-indigo-500 mb-1 font-medium">Across 16 servers</span>
                    </div>
                </div>
            </div>
        </div>
    );
};

export default Connectors;
