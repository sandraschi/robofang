import React from 'react';
import { motion } from 'framer-motion';
import { Activity, Clock, Zap, Shield } from 'lucide-react';

const Pulse: React.FC = () => {
    const pulses = [
        { id: 1, type: 'Security', content: 'Inbound packet filtered from unknown source.', time: '12s ago', severity: 'low' },
        { id: 2, type: 'Network', content: 'Latency spike detected in Frankfurt node (156ms).', time: '45s ago', severity: 'medium' },
        { id: 3, type: 'System', content: 'Orchestrator self-correction sequence initiated.', time: '2m ago', severity: 'high' },
        { id: 4, type: 'Resource', content: 'VRAM utilization at 82% (Ollama: Gemma 27B).', time: '5m ago', severity: 'medium' },
    ];

    return (
        <div className="space-y-8">
            <div className="flex flex-col gap-2">
                <h1 className="text-3xl font-bold text-white font-heading">Global Pulse</h1>
                <p className="text-slate-400">Real-time system telemetry and security events.</p>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
                {[
                    { label: 'Uptime', value: '14 days', icon: <Clock size={16} /> },
                    { label: 'Total Events', value: '12,842', icon: <Activity size={16} /> },
                    { label: 'Active Nodes', value: '16', icon: <Zap size={16} /> },
                    { label: 'Threat Level', value: 'Nominal', icon: <Shield size={16} /> },
                ].map((stat, i) => (
                    <div key={i} className="glass-panel p-6 bg-white/5 border-white/10 rounded-2xl flex flex-col gap-1">
                        <div className="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-slate-500">
                            {stat.icon}
                            <span>{stat.label}</span>
                        </div>
                        <span className="text-2xl font-bold text-white font-mono">{stat.value}</span>
                    </div>
                ))}
            </div>

            <div className="glass-panel bg-white/5 border-white/10 rounded-3xl overflow-hidden p-2">
                <div className="flex flex-col divide-y divide-white/5">
                    {pulses.map((pulse, idx) => (
                        <motion.div
                            key={pulse.id}
                            initial={{ opacity: 0, scale: 0.98 }}
                            animate={{ opacity: 1, scale: 1 }}
                            transition={{ delay: idx * 0.1 }}
                            className="p-6 flex items-center justify-between group hover:bg-white/2 transition-colors rounded-2xl"
                        >
                            <div className="flex items-center gap-6">
                                <div className={`w-2 h-2 rounded-full ${pulse.severity === 'high' ? 'bg-rose-500 shadow-[0_0_8px_rgba(244,63,94,0.5)]' :
                                    pulse.severity === 'medium' ? 'bg-amber-500' :
                                        'bg-indigo-500'
                                    }`} />
                                <div className="flex flex-col gap-1">
                                    <div className="flex items-center gap-3">
                                        <span className={`text-[10px] font-bold uppercase tracking-widest ${pulse.severity === 'high' ? 'text-rose-500' :
                                            pulse.severity === 'medium' ? 'text-amber-500' :
                                                'text-indigo-400'
                                            }`}>
                                            {pulse.type}
                                        </span>
                                        <span className="text-sm font-medium text-white">{pulse.content}</span>
                                    </div>
                                    <span className="text-[10px] text-slate-500 font-mono">Timestamp: 2026-02-22T16:54:23Z | Trace: {pulse.id.toString(36).padStart(6, '0')}</span>
                                </div>
                            </div>
                            <span className="text-xs font-mono text-slate-400">{pulse.time}</span>
                        </motion.div>
                    ))}
                </div>
            </div>
        </div>
    );
};

export default Pulse;
